# Twilio — phone-native messaging
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_IDENTITY=+1XXXXXXXXXX
# Set to "true" to enable Twilio Conversations API for real group MMS on shared threads.
# Requires +1 US/Canada long code number. Max 10 participants per conversation.
# When disabled, shared threads use per-recipient fan-out (logical grouping only).
TWILIO_CONVERSATIONS_ENABLED=false

# Anthropic — Claude API for classification and message composition
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email monitoring — IMAP inbox
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your_email@example.com
IMAP_PASSWORD=your_email_password_here

# ngrok — tunnel for Twilio webhooks only (CalDAV stays local)
NGROK_DOMAIN=your-subdomain.ngrok-free.app
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Local infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_PATH=./data/fcc.db
PORT=3000
CALDAV_PORT=3001
